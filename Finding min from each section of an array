#include<stdio.h>
#include<math.h>
int main()
{
  int a,b;
  scanf("%d%d",&a,&b);
  int arr[a];
  for(int i=0;i<a;i++)
    scanf("%d",&arr[i]);
  int div = a/b,t;
  if(div*b==a)
  {
      t = div;
  }
  else
    t = div + 1;
   for(int i=0;i<a;i=i+b)
   {
       int min = arr[i];

       for(int j=i;j<i+t && j<a;j++)
       {
           if(min>arr[j])
            min = arr[j];
       }
       printf("%d ",min);
   }
    return 0;
}
