#include<stdio.h>
#include<math.h>
int main()
{
    int a,b;

    scanf("%d%d",&a,&b);
    int arr[a][b];
    for(int i=0;i<a;i++)
    {
       for(int j=0;j<b;j++)
       {
           scanf("%d",&arr[i][j]);
       }
    }
    for(int i=0;i<a;i++)
    {
       for(int j=0;j<b/2;j++)
       {
          int temp = arr[i][j];
          arr[i][j]= arr[i][b-j-1];
          arr[i][b-j-1] = temp;

       }
    }
     for(int i=0;i<a;i++)
    {
       for(int j=0;j<b;j++)
       {
           printf("%d ",arr[i][j]);
       }
       printf("\n");
    }



return 0;}
