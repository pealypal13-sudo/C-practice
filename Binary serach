#include<stdio.h>
int main()
{
  int a;
  scanf("%d",&a);
  int arr[a],count=0;
  scanf("%d",&arr[0]);
  int min=arr[0];           //******* if min was declared inside the loop, we would have needed anather loop and this methood would not have worked
  for(int i=1;i<a;i++)
  {   
      scanf("%d",&arr[i]);
      if(min>arr[i]) min = arr[i];
  }
  for(int j=0;j<a;j++)
  {
     if(min==arr[j]) count++;
  }
  if(count%2==0) printf("Unlucky");
  else printf("Lucky");
  return 0;
}
