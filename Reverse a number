#include<stdio.h>
int main()
{
    int n;
    scanf("%d",&n);
   int real_number=n;
    int reverse=0;      //assignment must be done after input
    while(n>0)
    {
        reverse=reverse*10 + n%10;
        n/=10;
    }
    if(reverse==real_number)
    {  printf("%d\n",reverse);
        printf("YES");
    }
    else{ 
        printf("%d\n",reverse);
        printf("NO");

    }
    return 0;
}
