#include<stdio.h>
#include<math.h>
int main()
{
    int a,b,c;
    scanf("%d%d%d",&a,&b,&c);
    float area,s;
    s = (float)(a+b+c)/2;
    area = sqrt(s*(s-a)*(s-b)*(s-c));
    if(a<(b+c) && b<(a+c) && c<(a+b))
    {
        printf("Valid\n");
        printf("%f",area);
    }
    else
        printf("Invalid");
    return 0;
}
